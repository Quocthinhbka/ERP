# Mẫu file .env production trên MÁY CHỦ.
# Đặt file này NGOÀI thư mục repo (mặc định: $HOME/erp/.env) để deploy không ghi đè.
# scripts/deploy.sh sẽ symlink file này thành .env ở gốc repo.

# Database (đổi mật khẩu mạnh cho production)
DATABASE_URL=postgresql://erp:CHANGE_ME_STRONG@localhost:5432/erp_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=CHANGE_ME_STRONG

# JWT — BẮT BUỘC đổi thành chuỗi ngẫu nhiên dài
JWT_SECRET=CHANGE_ME_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies: bật secure vì chạy sau HTTPS
COOKIE_SECURE=true

# API
API_PORT=3000
API_CORS_ORIGIN=https://erp.example.com
UPLOAD_MAX_BYTES=5242880

# Web build dùng chung domain qua nginx proxy -> để trống dùng đường dẫn /api tương đối
VITE_API_URL=
