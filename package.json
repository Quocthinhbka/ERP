{
  "name": "erp-hyperlabs",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @erp/api dev",
    "dev:web": "pnpm --filter @erp/web dev",
    "dev:worker": "pnpm --filter @erp/worker dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
