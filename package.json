    "db:push": "prisma db push"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.0",
    "dotenv": "^16.4.0",
    "prisma": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcrypt": "^5.1.1",
    "pg": "^8.13.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
