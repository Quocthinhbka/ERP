# Database
DATABASE_URL=postgresql://erp:erp_secret@localhost:5432/erp_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=erp_redis_secret

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-use-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies (HttpOnly). Set COOKIE_SECURE=true behind HTTPS.
COOKIE_SECURE=false

# API
API_PORT=3000
API_CORS_ORIGIN=http://localhost:5173
UPLOAD_MAX_BYTES=5242880

# E2E only — Super Admin đầu tiên tạo qua POST /api/auth/bootstrap (DB trống)
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PHONE=0900000000
TEST_ADMIN_PASSWORD=change-me
TEST_ADMIN_FULL_NAME=E2E Admin
# Mã đăng nhập Super Admin khi DB đã có user (bootstrap trả 403). Mặc định: Admin
TEST_ADMIN_ACCOUNT_CODE=Admin

# Web — để trống để dùng Vite proxy /api → API (cookie same-site).
# Không dùng biến VITE_* cho thông tin đăng nhập admin.
VITE_API_URL=
