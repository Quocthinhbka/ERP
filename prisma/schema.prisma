generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  passwordHash         String             @map("password_hash")
  fullName             String             @map("full_name")
  employeeCode         String?            @unique @map("employee_code")
  isActive             Boolean            @default(true) @map("is_active")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  roles                UserRole[]
  managedCompanies     Company[]          @relation("CompanyManager")
  managedUnits         OrganizationUnit[] @relation("UnitManager")

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  module      String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Organization {
  id          String        @id @default(uuid())
  code        String        @unique @default("ORG")
  name        String
  description String?
  status      EntityStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  companies   Company[]

  @@map("organizations")
}

model Company {
  id                  String             @id @default(uuid())
  organizationId      String             @map("organization_id")
  code                String
  name                String
  description         String?
  managerName         String?            @map("manager_name")
  managerEmployeeCode String?            @map("manager_employee_code")
  managerUserId       String?            @map("manager_user_id")
  displayOrder        Int                @default(0) @map("display_order")
  status              EntityStatus       @default(ACTIVE)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  managerUser         User?              @relation("CompanyManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  units               OrganizationUnit[]

  @@unique([organizationId, code])
  @@map("companies")
}

model OrganizationUnit {
  id                  String             @id @default(uuid())
  companyId           String             @map("company_id")
  parentUnitId        String?            @map("parent_unit_id")
  code                String
  name                String
  description         String?
  managerName         String?            @map("manager_name")
  managerEmployeeCode String?            @map("manager_employee_code")
  managerUserId       String?            @map("manager_user_id")
  displayOrder        Int                @default(0) @map("display_order")
  status              EntityStatus       @default(ACTIVE)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentUnit          OrganizationUnit?  @relation("UnitTree", fields: [parentUnitId], references: [id], onDelete: Cascade)
  childUnits          OrganizationUnit[] @relation("UnitTree")
  managerUser         User?              @relation("UnitManager", fields: [managerUserId], references: [id], onDelete: SetNull)

  @@unique([companyId, code])
  @@map("organization_units")
}
