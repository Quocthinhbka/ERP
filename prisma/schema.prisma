generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                         String                 @id @default(uuid())
  email                      String                 @unique
  passwordHash               String                 @map("password_hash")
  fullName                   String                 @map("full_name")
  employeeCode               String?                @unique @map("employee_code")
  isActive                   Boolean                @default(true) @map("is_active")
  createdAt                  DateTime               @default(now()) @map("created_at")
  updatedAt                  DateTime               @updatedAt @map("updated_at")
  roles                      UserRole[]
  organizationLinkedProfiles Organization[]         @relation("OrgLinkedProfile")
  companyLinkedProfiles      Company[]              @relation("CompanyLinkedProfile")
  companyMemberProfiles      CompanyMember[]        @relation("CompanyMemberLinkedProfile")
  unitLinkedProfiles         OrganizationUnit[]     @relation("UnitLinkedProfile")
  unitMemberProfiles         OrganizationUnitMember[] @relation("UnitMemberLinkedProfile")

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  module      String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  representativeName  String?              @map("representative_name")
  linkedProfileUserId String?              @map("linked_profile_user_id")
  additionalInfo      String?              @map("additional_info")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  companies           Company[]
  members             OrganizationMember[]
  linkedProfileUser   User?                @relation("OrgLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  position       String
  memberName     String       @map("member_name")
  phone          String?
  email          String?
  additionalInfo String?      @map("additional_info")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_members")
}

model Company {
  id                  String             @id @default(uuid())
  organizationId      String             @map("organization_id")
  name                String
  taxId               String?            @map("tax_id")
  address             String?
  representativeName  String?            @map("representative_name")
  linkedProfileUserId String?            @map("linked_profile_user_id")
  phone               String?
  email               String?
  status              EntityStatus       @default(ACTIVE)
  sortOrder           Int                @default(0) @map("sort_order")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?              @relation("CompanyLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)
  members             CompanyMember[]
  units               OrganizationUnit[]

  @@map("companies")
}

model CompanyMember {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  position            String
  memberName          String   @map("member_name")
  linkedProfileUserId String?  @map("linked_profile_user_id")
  phone               String?
  email               String?
  additionalInfo      String?  @map("additional_info")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?    @relation("CompanyMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@map("company_members")
}

model OrganizationUnit {
  id                  String             @id @default(uuid())
  companyId           String             @map("company_id")
  parentUnitId        String?            @map("parent_unit_id")
  name                String
  managerName         String?            @map("manager_name")
  linkedProfileUserId String?            @map("linked_profile_user_id")
  status              EntityStatus       @default(ACTIVE)
  additionalInfo      String?            @map("additional_info")
  sortOrder           Int                @default(0) @map("sort_order")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentUnit          OrganizationUnit?  @relation("UnitTree", fields: [parentUnitId], references: [id], onDelete: Cascade)
  childUnits          OrganizationUnit[] @relation("UnitTree")
  linkedProfileUser   User?              @relation("UnitLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)
  members             OrganizationUnitMember[]

  @@map("organization_units")
}

model OrganizationUnitMember {
  id                  String           @id @default(uuid())
  unitId              String           @map("unit_id")
  position            String
  memberName          String           @map("member_name")
  linkedProfileUserId String?          @map("linked_profile_user_id")
  phone               String?
  email               String?
  additionalInfo      String?          @map("additional_info")
  sortOrder           Int              @default(0) @map("sort_order")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  unit                OrganizationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?            @relation("UnitMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@map("organization_unit_members")
}
