generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum PositionHolderKind {
  ORGANIZATION_REP
  COMPANY_REP
  UNIT_MANAGER
  UNIT_MEMBER
  ORGANIZATION_MEMBER
  COMPANY_MEMBER
}

enum EmployeeGender {
  MALE
  FEMALE
  OTHER
}

enum EmployeeProfileStatus {
  INCOMPLETE
  PENDING_REVIEW
  NEEDS_ADJUSTMENT
  VERIFIED
  EDIT_REQUESTED
  LOCKED
}

enum EmployeeEmploymentStatus {
  APPRENTICE
  INTERN
  PROBATION
  OFFICIAL
  RESIGNED
  OTHER
}

/**
 * Hiện diện / trạng thái làm việc hàng ngày (khác trạng thái lao động hợp đồng).
 */
enum EmployeeWorkPresenceStatus {
  WORKING
  ON_BREAK
  ON_LEAVE
  ABSENT
  UNKNOWN
}

enum EmployeeProfileFieldDataType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  PHONE
  EMAIL
  SELECT
  MULTISELECT
  BOOLEAN
  SECTION
}

enum EmployeeProfileEditRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id                           String                       @id @default(uuid())
  email                        String?                      @unique
  passwordHash                 String                       @map("password_hash")
  fullName                     String                       @map("full_name")
  accountCode                  String                       @unique @map("account_code")
  phone                        String?                      @unique
  linkedEmployeeProfileId      String?                      @unique @map("linked_employee_profile_id")
  isSuperAdmin                 Boolean                      @default(false) @map("is_super_admin")
  isActive                     Boolean                      @default(true) @map("is_active")
  mustChangePassword           Boolean                      @default(false) @map("must_change_password")
  createdAt                    DateTime                     @default(now()) @map("created_at")
  updatedAt                    DateTime                     @updatedAt @map("updated_at")
  refreshTokens                RefreshToken[]
  organizationLinkedProfiles   Organization[]               @relation("OrgLinkedProfile")
  organizationMemberProfiles   OrganizationMember[]         @relation("OrgMemberLinkedProfile")
  companyLinkedProfiles        Company[]                    @relation("CompanyLinkedProfile")
  companyMemberProfiles        CompanyMember[]              @relation("CompanyMemberLinkedProfile")
  unitLinkedProfiles           OrganizationUnit[]           @relation("UnitLinkedProfile")
  unitMemberProfiles           OrganizationUnitMember[]     @relation("UnitMemberLinkedProfile")
  linkedEmployeeProfile        EmployeeProfile?             @relation("UserEmployeeProfile", fields: [linkedEmployeeProfileId], references: [id], onDelete: SetNull)
  employeeEditRequests         EmployeeProfileEditRequest[] @relation("EmployeeEditRequestRequester")
  reviewedEmployeeEditRequests EmployeeProfileEditRequest[] @relation("EmployeeEditRequestReviewer")

  @@index([isSuperAdmin])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Permission {
  id            String                             @id @default(uuid())
  code          String                             @unique
  name          String
  module        String
  description   String?
  createdAt     DateTime                           @default(now()) @map("created_at")
  updatedAt     DateTime                           @updatedAt @map("updated_at")
  groupVersions PermissionGroupVersionPermission[]

  @@map("permissions")
}

model PermissionGroup {
  id          String                   @id @default(uuid())
  code        String                   @unique
  name        String
  description String?
  isDefault   Boolean                  @default(false) @map("is_default")
  createdById String?                  @map("created_by_id")
  updatedById String?                  @map("updated_by_id")
  deletedAt   DateTime?                @map("deleted_at")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  versions    PermissionGroupVersion[]

  @@index([deletedAt])
  @@map("permission_groups")
}

model PermissionGroupVersion {
  id                  String                             @id @default(uuid())
  permissionGroupId   String                             @map("permission_group_id")
  versionNumber       Int                                @default(0) @map("version_number")
  name                String
  isCustom            Boolean                            @default(false) @map("is_custom")
  createdAt           DateTime                           @default(now()) @map("created_at")
  updatedAt           DateTime                           @updatedAt @map("updated_at")
  permissionGroup     PermissionGroup                    @relation(fields: [permissionGroupId], references: [id], onDelete: Cascade)
  permissions         PermissionGroupVersionPermission[]
  positionPermissions PositionPermission[]

  @@unique([permissionGroupId, versionNumber])
  @@map("permission_group_versions")
}

model PermissionGroupVersionPermission {
  versionId    String                 @map("version_id")
  permissionId String                 @map("permission_id")
  createdAt    DateTime               @default(now()) @map("created_at")
  version      PermissionGroupVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  permission   Permission             @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([versionId, permissionId])
  @@map("permission_group_version_permissions")
}

model PositionPermission {
  id                       String                          @id @default(uuid())
  holderKind               PositionHolderKind              @map("holder_kind")
  holderId                 String                          @map("holder_id")
  permissionGroupVersionId String                          @map("permission_group_version_id")
  includeSelf              Boolean                         @default(true) @map("include_self")
  createdAt                DateTime                        @default(now()) @map("created_at")
  updatedAt                DateTime                        @updatedAt @map("updated_at")
  permissionGroupVersion   PermissionGroupVersion          @relation(fields: [permissionGroupVersionId], references: [id], onDelete: Restrict)
  parentScopes             PositionPermissionParentScope[]

  @@unique([holderKind, holderId])
  @@index([permissionGroupVersionId])
  @@map("position_permissions")
}

model PositionPermissionParentScope {
  id                   String             @id @default(uuid())
  positionPermissionId String             @map("position_permission_id")
  nodeType             String             @map("node_type")
  nodeId               String             @map("node_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  positionPermission   PositionPermission @relation(fields: [positionPermissionId], references: [id], onDelete: Cascade)

  @@unique([positionPermissionId, nodeType, nodeId])
  @@index([nodeType, nodeId])
  @@map("position_permission_parent_scopes")
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  representativeName  String?              @map("representative_name")
  linkedProfileUserId String?              @map("linked_profile_user_id")
  positionCode        String?              @unique @map("position_code")
  additionalInfo      String?              @map("additional_info")
  createdById         String?              @map("created_by_id")
  updatedById         String?              @map("updated_by_id")
  deletedAt           DateTime?            @map("deleted_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  companies           Company[]
  members             OrganizationMember[]
  linkedProfileUser   User?                @relation("OrgLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@index([deletedAt])
  @@map("organizations")
}

model OrganizationMember {
  id                  String       @id @default(uuid())
  organizationId      String       @map("organization_id")
  position            String
  memberName          String       @map("member_name")
  linkedProfileUserId String?      @map("linked_profile_user_id")
  positionCode        String?      @unique @map("position_code")
  phone               String?
  email               String?
  additionalInfo      String?      @map("additional_info")
  sortOrder           Int          @default(0) @map("sort_order")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?        @relation("OrgMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, sortOrder])
  @@map("organization_members")
}

model Company {
  id                  String             @id @default(uuid())
  organizationId      String             @map("organization_id")
  name                String
  taxId               String?            @map("tax_id")
  address             String?
  representativeName  String?            @map("representative_name")
  linkedProfileUserId String?            @map("linked_profile_user_id")
  positionCode        String?            @unique @map("position_code")
  phone               String?
  email               String?
  status              EntityStatus       @default(ACTIVE)
  sortOrder           Int                @default(0) @map("sort_order")
  createdById         String?            @map("created_by_id")
  updatedById         String?            @map("updated_by_id")
  deletedAt           DateTime?          @map("deleted_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?              @relation("CompanyLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)
  members             CompanyMember[]
  units               OrganizationUnit[]
  employeeProfiles    EmployeeProfile[]  @relation("EmployeeManagingCompany")

  @@index([organizationId, sortOrder])
  @@index([deletedAt])
  @@map("companies")
}

model CompanyMember {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  position            String
  memberName          String   @map("member_name")
  linkedProfileUserId String?  @map("linked_profile_user_id")
  positionCode        String?  @unique @map("position_code")
  phone               String?
  email               String?
  additionalInfo      String?  @map("additional_info")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?    @relation("CompanyMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@index([companyId, sortOrder])
  @@map("company_members")
}

model OrganizationUnit {
  id                  String                   @id @default(uuid())
  companyId           String                   @map("company_id")
  parentUnitId        String?                  @map("parent_unit_id")
  name                String
  managerName         String?                  @map("manager_name")
  linkedProfileUserId String?                  @map("linked_profile_user_id")
  positionCode        String?                  @unique @map("position_code")
  status              EntityStatus             @default(ACTIVE)
  additionalInfo      String?                  @map("additional_info")
  sortOrder           Int                      @default(0) @map("sort_order")
  createdById         String?                  @map("created_by_id")
  updatedById         String?                  @map("updated_by_id")
  deletedAt           DateTime?                @map("deleted_at")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  company             Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentUnit          OrganizationUnit?        @relation("UnitTree", fields: [parentUnitId], references: [id], onDelete: Restrict)
  childUnits          OrganizationUnit[]       @relation("UnitTree")
  linkedProfileUser   User?                    @relation("UnitLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)
  members             OrganizationUnitMember[]

  @@index([companyId, sortOrder])
  @@index([parentUnitId])
  @@index([deletedAt])
  @@map("organization_units")
}

model OrganizationUnitMember {
  id                  String           @id @default(uuid())
  unitId              String           @map("unit_id")
  position            String
  memberName          String           @map("member_name")
  linkedProfileUserId String?          @map("linked_profile_user_id")
  positionCode        String?          @unique @map("position_code")
  phone               String?
  email               String?
  additionalInfo      String?          @map("additional_info")
  sortOrder           Int              @default(0) @map("sort_order")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  unit                OrganizationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?            @relation("UnitMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@index([unitId, sortOrder])
  @@map("organization_unit_members")
}

model EmployeeProfile {
  id                       String                       @id @default(uuid())
  profileCode              String                       @unique @map("profile_code")
  fullName                 String                       @map("full_name")
  gender                   EmployeeGender?
  birthDate                DateTime?                    @map("birth_date") @db.Date
  birthPlace               String?                      @map("birth_place")
  placeOfOrigin            String?                      @map("place_of_origin")
  permanentAddress         String?                      @map("permanent_address")
  currentAddress           String?                      @map("current_address")
  phone                    String
  email                    String?
  ethnicity                String?
  religion                 String?
  identityNumber           String?                      @map("identity_number")
  identityIssuedDate       DateTime?                    @map("identity_issued_date") @db.Date
  identityIssuedPlace      String?                      @map("identity_issued_place")
  educationLevel           String?                      @map("education_level")
  youthUnionAdmissionDate  DateTime?                    @map("youth_union_admission_date") @db.Date
  youthUnionAdmissionPlace String?                      @map("youth_union_admission_place")
  partyAdmissionDate       DateTime?                    @map("party_admission_date") @db.Date
  partyAdmissionPlace      String?                      @map("party_admission_place")
  rewardDiscipline         String?                      @map("reward_discipline")
  strengths                String?
  avatarUrl                String?                      @map("avatar_url")
  managingCompanyId        String?                      @map("managing_company_id")
  employmentStatus         EmployeeEmploymentStatus?    @map("employment_status")
  workPresenceStatus       EmployeeWorkPresenceStatus   @default(UNKNOWN) @map("work_presence_status")
  status                   EmployeeProfileStatus        @default(INCOMPLETE)
  createdById              String?                      @map("created_by_id")
  updatedById              String?                      @map("updated_by_id")
  deletedAt                DateTime?                    @map("deleted_at")
  createdAt                DateTime                     @default(now()) @map("created_at")
  updatedAt                DateTime                     @updatedAt @map("updated_at")
  managingCompany          Company?                     @relation("EmployeeManagingCompany", fields: [managingCompanyId], references: [id], onDelete: SetNull)
  linkedUser               User?                        @relation("UserEmployeeProfile")
  familyMembers            EmployeeFamilyMember[]
  educationHistories       EmployeeEducationHistory[]
  workHistories            EmployeeWorkHistory[]
  editRequests             EmployeeProfileEditRequest[]
  documents                EmployeeDocument[]
  customFieldValues        EmployeeProfileFieldValue[]

  @@index([fullName])
  @@index([phone])
  @@index([email])
  @@index([identityNumber])
  @@index([status])
  @@index([managingCompanyId])
  @@index([deletedAt])
  @@map("employee_profiles")
}

model EmployeeDocument {
  id                String          @id @default(uuid())
  employeeProfileId String          @map("employee_profile_id")
  documentType      String          @map("document_type")
  name              String
  originalFileName  String          @map("original_file_name")
  mimeType          String          @map("mime_type")
  size              Int
  fileUrl           String          @map("file_url")
  createdById       String?         @map("created_by_id")
  deletedAt         DateTime?       @map("deleted_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  profile           EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId, createdAt])
  @@index([deletedAt])
  @@map("employee_documents")
}

model EmployeeProfileEditRequest {
  id                String                           @id @default(uuid())
  employeeProfileId String                           @map("employee_profile_id")
  requestedByUserId String                           @map("requested_by_user_id")
  reviewedByUserId  String?                          @map("reviewed_by_user_id")
  status            EmployeeProfileEditRequestStatus @default(PENDING)
  reason            String?
  reviewNote        String?                          @map("review_note")
  reviewedAt        DateTime?                        @map("reviewed_at")
  createdAt         DateTime                         @default(now()) @map("created_at")
  updatedAt         DateTime                         @updatedAt @map("updated_at")
  employeeProfile   EmployeeProfile                  @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  requestedBy       User                             @relation("EmployeeEditRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy        User?                            @relation("EmployeeEditRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeProfileId, status, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([status, createdAt])
  @@map("employee_profile_edit_requests")
}

model EmployeeFamilyMember {
  id                String          @id @default(uuid())
  employeeProfileId String          @map("employee_profile_id")
  relationship      String
  fullName          String          @map("full_name")
  birthYear         Int?            @map("birth_year")
  currentResidence  String?         @map("current_residence")
  occupation        String?
  workplace         String?
  sortOrder         Int             @default(0) @map("sort_order")
  profile           EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
  @@map("employee_family_members")
}

model EmployeeEducationHistory {
  id                String          @id @default(uuid())
  employeeProfileId String          @map("employee_profile_id")
  fromMonth         DateTime        @map("from_month") @db.Date
  toMonth           DateTime        @map("to_month") @db.Date
  institution       String
  major             String
  trainingMode      String          @map("training_mode")
  degree            String
  sortOrder         Int             @default(0) @map("sort_order")
  profile           EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
  @@map("employee_education_histories")
}

model EmployeeWorkHistory {
  id                String          @id @default(uuid())
  employeeProfileId String          @map("employee_profile_id")
  fromMonth         DateTime        @map("from_month") @db.Date
  toMonth           DateTime?       @map("to_month") @db.Date
  company           String
  department        String?
  position          String
  sortOrder         Int             @default(0) @map("sort_order")
  profile           EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
  @@map("employee_work_histories")
}

model EmployeeProfileTab {
  id        String                    @id @default(uuid())
  code      String                    @unique
  name      String
  sortOrder Int                       @default(0) @map("sort_order")
  isSystem  Boolean                   @default(false) @map("is_system")
  visible   Boolean                   @default(true)
  createdAt DateTime                  @default(now()) @map("created_at")
  updatedAt DateTime                  @updatedAt @map("updated_at")
  fields    EmployeeProfileTabField[]

  @@map("employee_profile_tabs")
}

model EmployeeProfileFieldDef {
  id         String                       @id @default(uuid())
  code       String                       @unique
  label      String
  dataType   EmployeeProfileFieldDataType @map("data_type")
  /// Với SECTION: family | education | work. Với SELECT: danh sách lựa chọn...
  options    Json?
  required   Boolean                      @default(false)
  visible    Boolean                      @default(true)
  isSystem   Boolean                      @default(false) @map("is_system")
  locked     Boolean                      @default(false)
  /// Cột EmployeeProfile nếu là built-in; null = custom JSON value
  storageKey String?                      @map("storage_key")
  sortOrder  Int                          @default(0) @map("sort_order")
  createdAt  DateTime                     @default(now()) @map("created_at")
  updatedAt  DateTime                     @updatedAt @map("updated_at")
  tabLinks   EmployeeProfileTabField[]
  values     EmployeeProfileFieldValue[]

  @@map("employee_profile_field_defs")
}

model EmployeeProfileTabField {
  id         String                  @id @default(uuid())
  tabId      String                  @map("tab_id")
  fieldDefId String                  @map("field_def_id")
  sortOrder  Int                     @default(0) @map("sort_order")
  tab        EmployeeProfileTab      @relation(fields: [tabId], references: [id], onDelete: Cascade)
  fieldDef   EmployeeProfileFieldDef @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)

  @@unique([tabId, fieldDefId])
  @@index([tabId, sortOrder])
  @@map("employee_profile_tab_fields")
}

model EmployeeProfileFieldValue {
  id         String                  @id @default(uuid())
  profileId  String                  @map("profile_id")
  fieldDefId String                  @map("field_def_id")
  value      Json
  updatedAt  DateTime                @updatedAt @map("updated_at")
  profile    EmployeeProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fieldDef   EmployeeProfileFieldDef @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)

  @@unique([profileId, fieldDefId])
  @@index([profileId])
  @@map("employee_profile_field_values")
}
