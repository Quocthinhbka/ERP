generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum PositionHolderKind {
  ORGANIZATION_REP
  COMPANY_REP
  UNIT_MANAGER
  UNIT_MEMBER
}

enum EmployeeGender {
  MALE
  FEMALE
  OTHER
}

model User {
  id                         String                   @id @default(uuid())
  email                      String?                  @unique
  passwordHash               String                   @map("password_hash")
  fullName                   String                   @map("full_name")
  accountCode                String                   @unique @map("account_code")
  phone                      String?                  @unique
  linkedEmployeeProfileId    String?                  @unique @map("linked_employee_profile_id")
  isActive                   Boolean                  @default(true) @map("is_active")
  mustChangePassword         Boolean                  @default(false) @map("must_change_password")
  createdAt                  DateTime                 @default(now()) @map("created_at")
  updatedAt                  DateTime                 @updatedAt @map("updated_at")
  roles                      UserRole[]
  refreshTokens              RefreshToken[]
  organizationLinkedProfiles Organization[]           @relation("OrgLinkedProfile")
  organizationMemberProfiles OrganizationMember[]     @relation("OrgMemberLinkedProfile")
  companyLinkedProfiles      Company[]                @relation("CompanyLinkedProfile")
  companyMemberProfiles      CompanyMember[]          @relation("CompanyMemberLinkedProfile")
  unitLinkedProfiles         OrganizationUnit[]       @relation("UnitLinkedProfile")
  unitMemberProfiles         OrganizationUnitMember[] @relation("UnitMemberLinkedProfile")
  linkedEmployeeProfile      EmployeeProfile?         @relation("UserEmployeeProfile", fields: [linkedEmployeeProfileId], references: [id], onDelete: SetNull)

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id            String                             @id @default(uuid())
  code          String                             @unique
  name          String
  module        String
  description   String?
  createdAt     DateTime                           @default(now()) @map("created_at")
  updatedAt     DateTime                           @updatedAt @map("updated_at")
  roles         RolePermission[]
  groups        PermissionGroupPermission[]
  groupVersions PermissionGroupVersionPermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model PermissionGroup {
  id          String                      @id @default(uuid())
  code        String                      @unique
  name        String
  description String?
  isDefault   Boolean                     @default(false) @map("is_default")
  createdAt   DateTime                    @default(now()) @map("created_at")
  updatedAt   DateTime                    @updatedAt @map("updated_at")
  permissions PermissionGroupPermission[]
  versions    PermissionGroupVersion[]

  @@map("permission_groups")
}

model PermissionGroupPermission {
  permissionGroupId String          @map("permission_group_id")
  permissionId      String          @map("permission_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  permissionGroup   PermissionGroup @relation(fields: [permissionGroupId], references: [id], onDelete: Cascade)
  permission        Permission      @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([permissionGroupId, permissionId])
  @@map("permission_group_permissions")
}

model PermissionGroupVersion {
  id                  String                             @id @default(uuid())
  permissionGroupId   String                             @map("permission_group_id")
  versionNumber       Int                                @default(0) @map("version_number")
  name                String
  isCustom            Boolean                            @default(false) @map("is_custom")
  createdAt           DateTime                           @default(now()) @map("created_at")
  updatedAt           DateTime                           @updatedAt @map("updated_at")
  permissionGroup     PermissionGroup                    @relation(fields: [permissionGroupId], references: [id], onDelete: Cascade)
  permissions         PermissionGroupVersionPermission[]
  positionPermissions PositionPermission[]

  @@unique([permissionGroupId, versionNumber])
  @@map("permission_group_versions")
}

model PermissionGroupVersionPermission {
  versionId    String                 @map("version_id")
  permissionId String                 @map("permission_id")
  createdAt    DateTime               @default(now()) @map("created_at")
  version      PermissionGroupVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  permission   Permission             @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([versionId, permissionId])
  @@map("permission_group_version_permissions")
}

model PositionPermission {
  id                       String                          @id @default(uuid())
  holderKind               PositionHolderKind              @map("holder_kind")
  holderId                 String                          @map("holder_id")
  permissionGroupVersionId String                          @map("permission_group_version_id")
  includeSelf              Boolean                         @default(true) @map("include_self")
  createdAt                DateTime                        @default(now()) @map("created_at")
  updatedAt                DateTime                        @updatedAt @map("updated_at")
  permissionGroupVersion   PermissionGroupVersion          @relation(fields: [permissionGroupVersionId], references: [id], onDelete: Restrict)
  parentScopes             PositionPermissionParentScope[]

  @@unique([holderKind, holderId])
  @@index([holderId])
  @@map("position_permissions")
}

model PositionPermissionParentScope {
  id                   String             @id @default(uuid())
  positionPermissionId String             @map("position_permission_id")
  nodeType             String             @map("node_type")
  nodeId               String             @map("node_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  positionPermission   PositionPermission @relation(fields: [positionPermissionId], references: [id], onDelete: Cascade)

  @@unique([positionPermissionId, nodeType, nodeId])
  @@map("position_permission_parent_scopes")
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  representativeName  String?              @map("representative_name")
  linkedProfileUserId String?              @map("linked_profile_user_id")
  additionalInfo      String?              @map("additional_info")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  companies           Company[]
  members             OrganizationMember[]
  linkedProfileUser   User?                @relation("OrgLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@map("organizations")
}

model OrganizationMember {
  id                  String       @id @default(uuid())
  organizationId      String       @map("organization_id")
  position            String
  memberName          String       @map("member_name")
  linkedProfileUserId String?      @map("linked_profile_user_id")
  phone               String?
  email               String?
  additionalInfo      String?      @map("additional_info")
  sortOrder           Int          @default(0) @map("sort_order")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?        @relation("OrgMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@map("organization_members")
}

model Company {
  id                  String             @id @default(uuid())
  organizationId      String             @map("organization_id")
  name                String
  taxId               String?            @map("tax_id")
  address             String?
  representativeName  String?            @map("representative_name")
  linkedProfileUserId String?            @map("linked_profile_user_id")
  phone               String?
  email               String?
  status              EntityStatus       @default(ACTIVE)
  sortOrder           Int                @default(0) @map("sort_order")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?              @relation("CompanyLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)
  members             CompanyMember[]
  units               OrganizationUnit[]

  @@map("companies")
}

model CompanyMember {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  position            String
  memberName          String   @map("member_name")
  linkedProfileUserId String?  @map("linked_profile_user_id")
  phone               String?
  email               String?
  additionalInfo      String?  @map("additional_info")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?    @relation("CompanyMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@map("company_members")
}

model OrganizationUnit {
  id                  String                   @id @default(uuid())
  companyId           String                   @map("company_id")
  parentUnitId        String?                  @map("parent_unit_id")
  name                String
  managerName         String?                  @map("manager_name")
  linkedProfileUserId String?                  @map("linked_profile_user_id")
  status              EntityStatus             @default(ACTIVE)
  additionalInfo      String?                  @map("additional_info")
  sortOrder           Int                      @default(0) @map("sort_order")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  company             Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentUnit          OrganizationUnit?        @relation("UnitTree", fields: [parentUnitId], references: [id], onDelete: Cascade)
  childUnits          OrganizationUnit[]       @relation("UnitTree")
  linkedProfileUser   User?                    @relation("UnitLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)
  members             OrganizationUnitMember[]

  @@map("organization_units")
}

model OrganizationUnitMember {
  id                  String           @id @default(uuid())
  unitId              String           @map("unit_id")
  position            String
  memberName          String           @map("member_name")
  linkedProfileUserId String?          @map("linked_profile_user_id")
  phone               String?
  email               String?
  additionalInfo      String?          @map("additional_info")
  sortOrder           Int              @default(0) @map("sort_order")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  unit                OrganizationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  linkedProfileUser   User?            @relation("UnitMemberLinkedProfile", fields: [linkedProfileUserId], references: [id], onDelete: SetNull)

  @@map("organization_unit_members")
}

model EmployeeProfile {
  id                       String                     @id @default(uuid())
  profileCode              String                     @unique @map("profile_code")
  fullName                 String                     @map("full_name")
  gender                   EmployeeGender
  birthDate                DateTime                   @map("birth_date") @db.Date
  birthPlace               String                     @map("birth_place")
  placeOfOrigin            String                     @map("place_of_origin")
  permanentAddress         String                     @map("permanent_address")
  currentAddress           String                     @map("current_address")
  phone                    String                     @unique
  email                    String                     @unique
  ethnicity                String
  religion                 String?
  identityNumber           String                     @unique @map("identity_number")
  identityIssuedDate       DateTime                   @map("identity_issued_date") @db.Date
  identityIssuedPlace      String                     @map("identity_issued_place")
  educationLevel           String                     @map("education_level")
  youthUnionAdmissionDate  DateTime?                  @map("youth_union_admission_date") @db.Date
  youthUnionAdmissionPlace String?                    @map("youth_union_admission_place")
  partyAdmissionDate       DateTime?                  @map("party_admission_date") @db.Date
  partyAdmissionPlace      String?                    @map("party_admission_place")
  rewardDiscipline         String?                    @map("reward_discipline")
  strengths                String?
  status                   EntityStatus               @default(ACTIVE)
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")
  linkedUser               User?                      @relation("UserEmployeeProfile")
  familyMembers            EmployeeFamilyMember[]
  educationHistories       EmployeeEducationHistory[]
  workHistories            EmployeeWorkHistory[]

  @@index([fullName])
  @@index([phone])
  @@index([email])
  @@index([identityNumber])
  @@index([status])
  @@map("employee_profiles")
}

model EmployeeFamilyMember {
  id                String          @id @default(uuid())
  employeeProfileId String          @map("employee_profile_id")
  relationship      String
  fullName          String          @map("full_name")
  birthYear         Int?            @map("birth_year")
  currentResidence  String?         @map("current_residence")
  occupation        String?
  workplace         String?
  sortOrder         Int             @default(0) @map("sort_order")
  profile           EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
  @@map("employee_family_members")
}

model EmployeeEducationHistory {
  id                String          @id @default(uuid())
  employeeProfileId String          @map("employee_profile_id")
  fromMonth         DateTime        @map("from_month") @db.Date
  toMonth           DateTime        @map("to_month") @db.Date
  institution       String
  major             String
  trainingMode      String          @map("training_mode")
  degree            String
  sortOrder         Int             @default(0) @map("sort_order")
  profile           EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
  @@map("employee_education_histories")
}

model EmployeeWorkHistory {
  id                String          @id @default(uuid())
  employeeProfileId String          @map("employee_profile_id")
  fromMonth         DateTime        @map("from_month") @db.Date
  toMonth           DateTime?       @map("to_month") @db.Date
  company           String
  department        String?
  position          String
  sortOrder         Int             @default(0) @map("sort_order")
  profile           EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)

  @@index([employeeProfileId])
  @@map("employee_work_histories")
}
